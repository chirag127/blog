---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Finishing sign-in"
  description="Completing email-link sign-in."
>
  <section class="container mx-auto max-w-2xl px-4 py-20 text-center">
    <h1 class="text-2xl font-semibold mb-3">Finishing sign-in…</h1>
    <p class="text-neutral-400 mb-6">
      If you opened this page from an email link, we will complete sign-in
      automatically. Otherwise, head to
      <a href="/account/" class="text-amber-400 underline">your account</a>.
    </p>
    <p class="text-sm text-neutral-500">
      The full email-link handler is provided by the oriz auth hub at
      <a href="https://oriz.in/account/finish-sign-in/" class="underline">oriz.in</a>.
    </p>
  </section>
</BaseLayout>

<meta name="robots" content="noindex" slot="head" />
