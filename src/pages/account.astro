---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Account"
  description="Sign in to oriz. One account works across every oriz site."
>
  <header class="container mx-auto max-w-4xl px-4 pt-12 pb-6 border-b border-neutral-800">
    <p class="text-sm text-neutral-400 mb-2">
      <a href="/" class="hover:text-neutral-200">Blog</a> / Account
    </p>
    <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">Account</h1>
    <p class="mt-3 text-neutral-300 max-w-prose">
      One sign-in works across every oriz site (oriz.in, blog.oriz.in,
      books.oriz.in, …). Bookmarks, reading history, and preferences follow
      you. Sign-in lives at <a class="underline" href="https://oriz.in/account/">oriz.in/account</a>;
      this is a placeholder while the cross-site auth UI is wired up.
    </p>
  </header>

  <section class="container mx-auto max-w-4xl px-4 py-10">
    <noscript>
      <p class="text-neutral-400">JavaScript is required for the account panel.</p>
    </noscript>

    <div class="rounded-xl border border-neutral-800 bg-neutral-900/40 p-6">
      <h2 class="text-xl font-semibold mb-2">Cross-site sign-in</h2>
      <p class="text-neutral-300 mb-4">
        Sign in once at <code class="rounded bg-neutral-800 px-1.5 py-0.5">auth.oriz.in</code>
        and you are signed in across every <code class="rounded bg-neutral-800 px-1.5 py-0.5">*.oriz.in</code> site.
      </p>
      <a
        href="https://oriz.in/account/"
        class="inline-flex items-center gap-2 rounded-lg bg-amber-500 px-4 py-2 text-neutral-950 font-medium hover:bg-amber-400 transition"
      >
        Sign in at oriz.in →
      </a>
    </div>
  </section>
</BaseLayout>

<meta name="robots" content="noindex" slot="head" />
