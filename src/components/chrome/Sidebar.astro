---
/*
 * Sidebar — collapsible aside with pure-CSS mobile toggle.
 *
 * Props:
 *   collapsible? (default true), position? 'left'|'right' (default 'left'),
 *   width? (default '240px')
 *
 * Slots: default (nav items), header, footer.
 * Mobile (<768px): hidden off-canvas; a pure-CSS checkbox + label drives the toggle.
 */
interface Props {
  collapsible?: boolean
  position?: 'left' | 'right'
  width?: string
}
const { collapsible = true, position = 'left', width = '240px' } = Astro.props
const hasHeader = Astro.slots.has('header')
const hasFooter = Astro.slots.has('footer')
---
{collapsible && (
  <>
    <input type="checkbox" id="sb-toggle" class="sb-toggle" hidden />
    <label for="sb-toggle" class="sb-burger" aria-label="Toggle sidebar"><span></span><span></span><span></span></label>
  </>
)}
<aside class:list={["site-sidebar", `is-${position}`]} style={`--sb-w:${width};`} aria-label="sidebar">
  {hasHeader && <div class="sb-head"><slot name="header" /></div>}
  <nav class="sb-nav"><slot /></nav>
  {hasFooter && <div class="sb-foot"><slot name="footer" /></div>}
</aside>
<style>
  .sb-toggle { position: absolute; opacity: 0; pointer-events: none; }
  .sb-burger { display: none; position: fixed; top: 12px; left: 12px; z-index: 60; width: 40px; height: 40px; flex-direction: column; justify-content: center; align-items: center; gap: 4px; background: var(--color-paper, var(--paper)); border: 1px solid var(--color-rule, var(--rule)); border-radius: 4px; cursor: pointer; }
  .sb-burger span { display: block; width: 20px; height: 2px; background: var(--color-ink, var(--ink)); }
  .site-sidebar { width: var(--sb-w, 240px); flex: 0 0 var(--sb-w, 240px); position: sticky; top: 60px; align-self: flex-start; max-height: calc(100vh - 60px); overflow-y: auto; padding: 16px; border-right: 1px solid var(--color-rule, var(--rule)); background: var(--color-paper-2, var(--paper-2)); }
  .site-sidebar.is-right { border-right: 0; border-left: 1px solid var(--color-rule, var(--rule)); order: 2; }
  .sb-head { padding-bottom: 12px; margin-bottom: 12px; border-bottom: 1px solid var(--color-rule, var(--rule)); }
  .sb-nav { display: flex; flex-direction: column; gap: 4px; }
  .sb-foot { padding-top: 12px; margin-top: 12px; border-top: 1px solid var(--color-rule, var(--rule)); }
  @media (max-width: 767px) {
    .sb-burger { display: inline-flex; }
    .site-sidebar { position: fixed; top: 0; left: 0; bottom: 0; z-index: 55; transform: translateX(-100%); transition: transform 0.2s ease; max-height: 100vh; border-right: 1px solid var(--color-rule, var(--rule)); }
    .site-sidebar.is-right { left: auto; right: 0; transform: translateX(100%); }
    .sb-toggle:checked ~ .site-sidebar { transform: translateX(0); }
  }
</style>
