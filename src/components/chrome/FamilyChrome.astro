---
interface Props {
  slug?: string
  title: string
  titleHref?: string
  accent?: string
}

const { title, titleHref = '/', accent = '#c1440e' } = Astro.props
---

<header class="family-chrome" style={`--family-accent:${accent}`}>
  <nav class="family-chrome__inner" aria-label="Family">
    <a class="family-chrome__title" href={titleHref}>
      <span class="family-chrome__mark" aria-hidden="true">o</span>
      <span>{title}</span>
    </a>
    <span class="family-chrome__spacer" aria-hidden="true"></span>
    <a class="family-chrome__link" href="https://oriz.in">Family</a>
    <a class="family-chrome__link" href="https://github.com/chirag127/blog">Source</a>
  </nav>
</header>

<style>
  .family-chrome { position: sticky; top: 0; z-index: 100; background: #faf6ef; border-bottom: 1px solid #15140f; font-family: var(--font-sans, system-ui); font-size: 14px; }
  .family-chrome__inner { max-width: 1280px; margin: 0 auto; padding: 10px 20px; display: flex; align-items: center; gap: 18px; }
  .family-chrome__title { display: flex; align-items: center; gap: 8px; text-decoration: none; color: #15140f; font-weight: 600; }
  .family-chrome__mark { display: inline-grid; place-items: center; width: 22px; height: 22px; background: var(--family-accent); color: #faf6ef; font-weight: 700; }
  .family-chrome__spacer { flex: 1; }
  .family-chrome__link { color: #3a3a36; text-decoration: none; border-bottom: 1px solid transparent; }
  .family-chrome__link:hover { border-bottom-color: #15140f; }
</style>
