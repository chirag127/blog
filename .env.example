# ==============================================================================
#                 ENVIRONMENT VARIABLES FOR BLOG.ORIZ.IN
# ==============================================================================
# Copy this file to '.env' in your local environment.
# For automated CI/CD deployments via GitHub Actions and Cloudflare Pages:
# 1. Astro public variables (e.g. PUBLIC_SITE_URL) go in your Cloudflare Pages 
#    Dashboard under: Workers & Pages → blog → Settings → Environment variables.
# 2. API integration secrets MUST be added to your GitHub repository under:
#    Settings → Secrets and variables → Actions → Repository Secrets.
# ==============================================================================

# ==========================================
# 1. CORE SITE CONFIGURATION
# ==========================================

# The canonical domain where your blog is hosted.
# Used by feed generators, sitemaps, and canonical SEO tags.
PUBLIC_SITE_URL=https://blog.oriz.in

# Cloudflare Web Analytics Beacon Token
# How to get it:
# 1. Log into your Cloudflare Dashboard (dash.cloudflare.com).
# 2. Go to: Web Analytics → Add a site (or select your existing domain).
# 3. Cloudflare will generate a JS Snippet. Locate the token string (looks like
#    a long alphanumeric string) inside the code: token: "your_token_here".
# 4. Paste that exact string here. Leave blank to disable analytics tracking.
PUBLIC_CF_BEACON=


# ==========================================
# 2. MULTI-PLATFORM SYNDICATION SECRETS
# ==========================================

# ------------------------------------------
# A. DEV.TO (Forem API v1)
# ------------------------------------------
# How to get it:
# 1. Sign in to your Dev.to account (dev.to).
# 2. Go to: Settings (via profile avatar) → Extensions.
# 3. Scroll down to the "DEV Community API Keys" section.
# 4. Enter a name for the key (e.g., "Oriz Blog Auto-Poster") and click "Generate API Key".
# 5. Copy the generated key and paste it below.
DEVTO_API_KEY=your_devto_api_key_here

# ------------------------------------------
# B. HASHNODE (GraphQL API v2)
# ------------------------------------------
# NOTE: As of May 2026, Hashnode has retired free access to its GraphQL API.
# Programmatic publishing now requires their paid Pro plan. If you are using the
# free tier, leave these empty to automatically skip Hashnode syndication.
#
# How to get HASHNODE_API_KEY (Personal Access Token):
# 1. Log into your Hashnode account and go to: Account Settings → Developer.
# 2. Click "Generate New Token".
# 3. Enter a label (e.g. "Oriz Blog CLI") and click "Generate".
# 4. Copy the token immediately.
HASHNODE_API_KEY=your_hashnode_pat_here
#
# How to get HASHNODE_PUBLICATION_ID:
# 1. Log into your blog's Hashnode Dashboard.
# 2. Inspect your browser's address bar URL. The ID is the long string of letters
#    and numbers after the dash (e.g. hashnode.com/dashboard/publication/{id}).
# 3. Copy and paste that ID below.
HASHNODE_PUBLICATION_ID=your_hashnode_publication_id_here

# ------------------------------------------
# C. MEDIUM (REST API)
# ------------------------------------------
# How to get it:
# 1. Log into your Medium account (medium.com).
# 2. Click on your profile picture → Settings → Security.
# 3. Under the "Integration tokens" section, enter a description (e.g., "Oriz Syndicator").
# 4. Click "Get integration token" and copy it.
# 5. Paste the token below.
MEDIUM_INTEGRATION_TOKEN=your_medium_integration_token_here

# ------------------------------------------
# D. WORDPRESS (REST API)
# ------------------------------------------
# Set up these variables to syndicate to a hosted WordPress blog (including
# WordPress.com's completely free hosted tier e.g., yourblog.wordpress.com).
#
# How to configure:
# 1. WORDPRESS_URL: Enter the fully qualified URL of your blog (e.g., https://yourblog.wordpress.com).
# 2. WORDPRESS_USERNAME: Your WordPress account login username.
# 3. WORDPRESS_APP_PASSWORD (Application Password):
#    - Log into your WordPress dashboard and go to: Users → Profile.
#    - Scroll down to "Application Passwords".
#    - Enter a name (e.g., "Oriz Syndication script") and click "Add New Application Password".
#    - Copy the generated 24-character password (with spaces included).
WORDPRESS_URL=https://your-wordpress-site-url
WORDPRESS_USERNAME=your_wordpress_username
WORDPRESS_APP_PASSWORD=your_wordpress_app_password_here

# ------------------------------------------
# E. GOOGLE BLOGGER (Blogger API v3)
# ------------------------------------------
# Blogger is a completely free hosted blogging service by Google. Programmatic
# publishing requires creating OAuth 2.0 credentials in the Google Cloud Console.
#
# How to configure:
# 1. BLOGGER_BLOG_ID: Go to blogger.com, log into your blog, and look at the URL.
#    Copy the numerical ID after the 'blogID=' query parameter.
# 2. BLOGGER_CLIENT_ID & BLOGGER_CLIENT_SECRET:
#    - Go to Google Cloud Console (console.cloud.google.com).
#    - Create a new project. Enable the "Blogger API v3" in the API Library.
#    - Go to: APIs & Services → Credentials → Create Credentials → OAuth Client ID.
#    - Set Application Type to "Web application".
#    - Add 'https://developers.google.com/oauthplayground' as an Authorized Redirect URI.
#    - Save and copy your "Client ID" and "Client Secret".
# 3. BLOGGER_REFRESH_TOKEN:
#    - Go to: developers.google.com/oauthplayground
#    - Click the Gear Icon (Settings) in the top-right corner.
#    - Check "Use your own OAuth credentials" and enter your Client ID & Client Secret.
#    - In the left-hand column, locate and select the "Blogger API v3" scope:
#      https://www.googleapis.com/auth/blogger
#    - Click "Authorize APIs", log in with your Google account, and approve permissions.
#    - Once redirected back to OAuth Playground, click "Exchange authorization code for tokens".
#    - Copy the permanent "Refresh Token" generated in Step 2.
BLOGGER_BLOG_ID=your_blogger_blog_id_here
BLOGGER_CLIENT_ID=your_blogger_google_client_id_here
# Keep this secure
BLOGGER_CLIENT_SECRET=your_blogger_google_client_secret_here
# Permanent OAuth session key
BLOGGER_REFRESH_TOKEN=your_blogger_google_refresh_token_here

# ------------------------------------------
# F. X / TWITTER (Twitter API v2)
# ------------------------------------------
# Syndicates a short summary and an automatically shortened link (via is.gd API).
# Requires a Twitter Developer account to generate OAuth 1.0a credentials.
#
# How to configure:
# 1. Go to the Twitter Developer Portal (developer.twitter.com) and go to Projects & Apps.
# 2. Create an App inside the portal.
# 3. Go to App Settings → User Authentication Settings and click "Set up":
#    - Enable "OAuth 1.0a".
#    - Set App Permissions to "Read and write".
#    - Callback URI: enter a dummy URL (e.g., http://localhost).
#    - Website URL: enter your blog domain (e.g., https://blog.oriz.in).
#    - Save the settings.
# 4. Navigate to the "Keys and tokens" tab:
#    - Generate "API Key" & "API Secret Key" (Consumer Key / Consumer Secret).
#    - Generate "Access Token" & "Access Token Secret" with "Read and Write" access.
X_CONSUMER_KEY=your_x_consumer_key_here
X_CONSUMER_SECRET=your_x_consumer_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here


# ==========================================
# 3. DEPLOYMENT SECRETS (GitHub Actions)
# ==========================================
# Do NOT store these in your local .env file.
# Add these directly to your GitHub Repository Secrets to automate deployment:
#
# 1. CLOUDFLARE_ACCOUNT_ID:
#    - Go to dash.cloudflare.com.
#    - Click on your account name.
#    - Locate the Account ID on the Overview sidebar or inside the browser URL.
# 2. CLOUDFLARE_API_TOKEN:
#    - Go to: dash.cloudflare.com/profile/api-tokens
#    - Click "Create Token".
#    - Use the "Cloudflare Pages" template (gives Read/Write permissions for Pages).
#    - Copy the generated API Token.
# ==============================================================================
